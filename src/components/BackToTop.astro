---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'ko' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<button
  type="button"
  data-back-to-top
  aria-label={t('common.backToTop')}
  title={t('common.backToTop')}
  class="back-to-top fixed bottom-4 right-4 z-40 grid h-12 w-12 place-items-center rounded-sm border border-ink bg-ink font-sans text-[1.25rem] text-on-primary opacity-0 invisible pointer-events-none hover:border-accent hover:bg-accent sm:bottom-5 sm:right-5"
>
  <span aria-hidden="true">↑</span>
</button>

<script>
  const backToTop = document.querySelector('[data-back-to-top]');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  const updateBackToTop = () => {
    if (!(backToTop instanceof HTMLButtonElement)) return;
    const visible = window.scrollY > 720;
    backToTop.classList.toggle('is-visible', visible);
  };

  window.addEventListener('scroll', updateBackToTop, { passive: true });
  updateBackToTop();

  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: reducedMotion.matches ? 'auto' : 'smooth' });
  });
</script>

<style>
  .back-to-top {
    transform: translateY(0.5rem);
    transition: opacity 160ms ease, transform 160ms ease, visibility 160ms;
  }

  .back-to-top.is-visible {
    visibility: visible;
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .back-to-top {
      transition: none;
    }
  }
</style>
