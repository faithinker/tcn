---
// People — parchment 카드(officer-card 토큰). 사진 대신 이니셜 모노그램.
// 이름(국/영) · 역할·국가 eyebrow · 소속 · bio · 배지(추후 공개 / 예시).
interface Props {
  name: string;
  nameEn?: string;
  role: string;
  affiliation?: string;
  country?: string;
  bio?: string;
  tba?: boolean;
  placeholder?: boolean;
}

const { name, nameEn, role, affiliation, country, bio, tba, placeholder } = Astro.props;

const monogram = tba ? (country?.charAt(0) ?? '·') : name.charAt(0).toUpperCase();
const badge = tba ? '추후 공개' : placeholder ? '예시' : null;
---

<article class="flex gap-4 rounded-sm border border-hairline bg-canvas-soft p-5 sm:p-6">
  <div
    class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-hairline-strong font-serif text-[1.375rem] font-semibold text-ink"
    aria-hidden="true"
  >
    {monogram}
  </div>
  <div class="min-w-0">
    <p class="eyebrow">{country ? `${role} · ${country}` : role}</p>
    <h3 class="mt-1 font-serif text-display-sm font-semibold text-ink">{name}</h3>
    {nameEn && nameEn !== name && <p class="font-sans text-body-sm text-body-muted">{nameEn}</p>}
    {affiliation && <p class="mt-2 font-serif text-body-serif text-body">{affiliation}</p>}
    {bio && <p class="mt-1 font-serif text-body-sm text-body-muted">{bio}</p>}
    {
      badge && (
        <p class="mt-3 inline-block rounded-sm border border-hairline px-2 py-0.5 font-sans text-caption font-bold uppercase tracking-widest text-body-muted">
          {badge}
        </p>
      )
    }
  </div>
</article>
