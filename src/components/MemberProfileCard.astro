---
import type { CollectionEntry } from 'astro:content';

interface Props {
  member: CollectionEntry<'members'>['data'];
  currentLabel: string;
  expertiseLabel: string;
  compact?: boolean;
  hideDuplicateName?: boolean;
}

const {
  member,
  currentLabel,
  expertiseLabel,
  compact = false,
  hideDuplicateName = false,
} = Astro.props;
const showEnglishName = member.nameEn && (!hideDuplicateName || member.nameEn !== member.name);
---

<article class:list={['profile-card', { 'profile-card-compact': compact }]}>
  <div class="flex min-h-10 items-start justify-between gap-5">
    <p class="font-sans text-caption font-bold uppercase text-accent">{member.role}</p>
    <p class="text-right font-sans text-caption font-bold text-body-muted">{member.country}</p>
  </div>
  <h2 class:list={['mt-3 font-serif font-semibold text-ink', compact ? 'text-[1.5rem]' : 'text-display-sm']}>
    {member.name}
  </h2>
  {showEnglishName && <p class="mt-1 font-sans text-body-sm font-bold text-body-muted">{member.nameEn}</p>}
  {member.position && (
    <p class="mt-6 font-serif text-body-serif font-semibold text-ink">
      <span class="current-label">{currentLabel}</span>{member.position}
    </p>
  )}
  {member.summary && <p class="profile-summary">{member.summary}</p>}
  {member.highlights && (
    <ul class="profile-highlights">
      {member.highlights.map((item) => <li><span aria-hidden="true">·</span><span>{item}</span></li>)}
    </ul>
  )}
  {member.expertise && (
    <ul class="expertise-list" aria-label={expertiseLabel}>
      {member.expertise.map((item) => <li>{item}</li>)}
    </ul>
  )}
</article>

<style>
  .profile-card {
    min-width: 0;
    background: var(--color-canvas);
    padding: 1.5rem 1.25rem 1.75rem;
  }
  .current-label {
    display: block;
    margin-bottom: .35rem;
    color: var(--color-body-muted);
    font-family: var(--font-sans);
    font-size: .6875rem;
    font-weight: 750;
    letter-spacing: .08em;
    line-height: 1.3;
    text-transform: uppercase;
  }
  .profile-summary {
    margin-top: 1.25rem;
    border-top: 1px solid var(--color-hairline);
    padding-top: 1.125rem;
    color: var(--color-body);
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.75;
  }
  .profile-highlights {
    margin-top: 1rem;
    border-top: 1px solid var(--color-hairline);
    padding-top: 1rem;
    color: var(--color-body);
    font-family: var(--font-serif);
    font-size: .9375rem;
    line-height: 1.65;
  }
  .profile-highlights li { display: grid; grid-template-columns: .75rem minmax(0, 1fr); gap: .25rem; }
  .profile-highlights li + li { margin-top: .4rem; }
  .profile-highlights li > span:first-child { color: var(--color-accent); font-weight: 700; }
  .expertise-list { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: 1.25rem; }
  .expertise-list li {
    border: 1px solid var(--color-hairline);
    padding: .3rem .55rem;
    color: var(--color-body-muted);
    font-family: var(--font-sans);
    font-size: .75rem;
    font-weight: 650;
    line-height: 1.25;
  }
  @media (min-width: 40rem) {
    .profile-card { padding: 2rem; }
    .profile-card-compact { padding-inline: 1.5rem; }
  }
</style>
