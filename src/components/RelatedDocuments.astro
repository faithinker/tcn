---
import { localizePath, useTranslations } from '../i18n/utils';
import type { UiLang } from '../i18n/ui';

interface Props {
  lang: UiLang;
  current: 'declaration' | 'bylaws' | 'founding';
}

const { lang, current } = Astro.props;
const t = useTranslations(lang);
const documents = [
  { id: 'declaration', label: t('nav.declaration'), href: '/about/declaration' },
  { id: 'bylaws', label: t('nav.bylaws'), href: '/about/bylaws' },
  { id: 'founding', label: t('nav.founding'), href: '/about/founding' },
];
---

<nav class="mt-6 flex flex-wrap items-baseline gap-x-5 gap-y-2 font-sans text-body-sm" aria-label={t('common.relatedDocuments')}>
  <span class="font-bold text-ink">{t('common.relatedDocuments')}</span>
  {documents.map((document) => {
    const isCurrent = document.id === current;
    return (
      <a
        href={localizePath(document.href, lang)}
        aria-current={isCurrent ? 'page' : undefined}
        class:list={[
          'font-bold no-underline transition-colors',
          isCurrent ? 'text-accent' : 'text-body-muted hover:text-link',
        ]}
      >
        {document.label}
      </a>
    );
  })}
</nav>
