---
import BaseLayout from '../layouts/BaseLayout.astro';
import MemberProfileCard from '../components/MemberProfileCard.astro';
import SectionTile from '../components/SectionTile.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl } from '../i18n/utils';
import { getContent } from '../i18n/content';

const lang = getLangFromUrl(Astro.url);
const copy = getContent(lang).people;
const members = (await getCollection('members'))
  .filter((member) => member.data.lang === lang && member.data.category === 'board' && !member.data.tba)
  .sort((a, b) => a.data.order - b.data.order);

const leadership = members.filter((member) => member.data.group === 'leadership');
const directors = members.filter((member) => member.data.group === 'directors');
const support = members.filter((member) => member.data.group === 'support');
const expertiseLabel = lang === 'ko' ? '전문 분야' : 'Areas of expertise';
---

<BaseLayout title={copy.title} description={copy.description}>
  <section class="bg-canvas px-5 py-12 sm:py-24">
    <div class="mx-auto max-w-[75rem]">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1 class="mt-3 font-serif text-display-lg font-semibold text-ink sm:text-display-hero">
        {copy.heroTitle}
      </h1>
      <p class="mt-6 max-w-[62ch] font-serif text-lead text-body">
        {copy.heroBody}
      </p>
    </div>
  </section>

  {/* 임시 A/B 선택 UI — 고객 확정 후 제거 예정 */}
  <section class="border-y border-hairline bg-canvas px-5 py-8 sm:py-10" aria-labelledby="layout-title">
    <div class="mx-auto max-w-[75rem]">
      <p class="eyebrow">{copy.layoutEyebrow}</p>
      <h2 id="layout-title" class="mt-3 font-serif text-display-sm font-semibold text-ink sm:text-display-md">
        {copy.layoutTitle}
      </h2>
      <p class="mt-2 max-w-[60ch] font-serif text-body-sm text-body-muted">{copy.layoutBody}</p>
      <div class="mt-5 grid gap-2 sm:grid-cols-2" role="group" aria-label={copy.layoutTitle}>
        <button
          type="button"
          class="layout-choice"
          data-layout-choice="1"
          aria-pressed="true"
          aria-controls="people-layout-1"
        >
          <span class="choice-title">{copy.layoutOne}</span>
          <span class="choice-body">{copy.layoutOneBody}</span>
        </button>
        <button
          type="button"
          class="layout-choice"
          data-layout-choice="2"
          aria-pressed="false"
          aria-controls="people-layout-2"
        >
          <span class="choice-title">{copy.layoutTwo}</span>
          <span class="choice-body">{copy.layoutTwoBody}</span>
        </button>
      </div>
    </div>
  </section>

  {/* 1번: 3구분 유지 + 그룹 설명문 전부 제거 */}
  <div id="people-layout-1" data-people-layout="1">
    <SectionTile variant="band" eyebrow={copy.leadershipEyebrow} title={copy.leadershipTitle}>
      <div class="profile-grid mt-8 grid gap-px border-y border-hairline-strong bg-hairline lg:grid-cols-2">
        {leadership.map((member) => (
          <MemberProfileCard member={member.data} currentLabel={copy.currentLabel} expertiseLabel={expertiseLabel} />
        ))}
      </div>
    </SectionTile>

    <SectionTile variant="canvas" eyebrow={copy.boardEyebrow} title={copy.boardTitle}>
      <div class="directors-grid profile-grid mt-8 grid gap-px border-y border-hairline-strong bg-hairline md:grid-cols-2 lg:grid-cols-3">
        {directors.map((member) => (
          <MemberProfileCard member={member.data} currentLabel={copy.currentLabel} expertiseLabel={expertiseLabel} compact />
        ))}
      </div>
    </SectionTile>

    <SectionTile variant="soft" eyebrow={copy.supportEyebrow} title={copy.supportTitle}>
      <div class="profile-grid mt-8 grid gap-px border-y border-hairline-strong bg-hairline lg:grid-cols-2">
        {support.map((member) => (
          <MemberProfileCard member={member.data} currentLabel={copy.currentLabel} expertiseLabel={expertiseLabel} hideDuplicateName />
        ))}
      </div>
    </SectionTile>
  </div>

  {/* 2번: 회장·부회장·이사 한 섹션 통합(설명문 살림) + 감사·고문 별도 */}
  <div id="people-layout-2" data-people-layout="2" hidden>
    <SectionTile variant="band" eyebrow={copy.boardEyebrow} title={copy.boardTitle}>
      <p class="mt-5 font-serif text-body-serif text-body-muted">{copy.boardBody}</p>
      <div class="profile-grid mt-8 grid gap-px border-t border-hairline-strong bg-hairline lg:grid-cols-2">
        {leadership.map((member) => (
          <MemberProfileCard member={member.data} currentLabel={copy.currentLabel} expertiseLabel={expertiseLabel} />
        ))}
      </div>
      <div class="directors-grid profile-grid grid gap-px border-y border-hairline-strong bg-hairline md:grid-cols-2 lg:grid-cols-3">
        {directors.map((member) => (
          <MemberProfileCard member={member.data} currentLabel={copy.currentLabel} expertiseLabel={expertiseLabel} compact />
        ))}
      </div>
    </SectionTile>

    <SectionTile variant="soft" eyebrow={copy.supportEyebrow} title={copy.supportTitle}>
      <p class="mt-5 font-serif text-body-serif text-body-muted">{copy.supportBody}</p>
      <div class="profile-grid mt-8 grid gap-px border-y border-hairline-strong bg-hairline lg:grid-cols-2">
        {support.map((member) => (
          <MemberProfileCard member={member.data} currentLabel={copy.currentLabel} expertiseLabel={expertiseLabel} hideDuplicateName />
        ))}
      </div>
    </SectionTile>
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const storageKey = 'tcn-people-layout';
    const buttons = Array.from(document.querySelectorAll('[data-layout-choice]'));
    const layouts = Array.from(document.querySelectorAll('[data-people-layout]'));

    const selectLayout = (value, persist = true) => {
      const selected = value === '2' ? '2' : '1';
      layouts.forEach((layout) => {
        layout.hidden = layout.getAttribute('data-people-layout') !== selected;
      });
      buttons.forEach((button) => {
        button.setAttribute('aria-pressed', String(button.getAttribute('data-layout-choice') === selected));
      });
      if (persist) {
        try { localStorage.setItem(storageKey, selected); } catch {}
        const url = new URL(window.location.href);
        url.searchParams.set('view', selected);
        history.replaceState(null, '', url);
      }
    };

    const queryChoice = new URL(window.location.href).searchParams.get('view');
    let savedChoice = null;
    try { savedChoice = localStorage.getItem(storageKey); } catch {}
    selectLayout(queryChoice || savedChoice || '1', queryChoice !== null);

    buttons.forEach((button) => {
      button.addEventListener('click', () => selectLayout(button.getAttribute('data-layout-choice')));
    });
  })();
</script>

<style>
  .layout-choice {
    min-height: 5.75rem;
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    padding: 1rem;
    text-align: left;
    transition: border-color 150ms ease, background-color 150ms ease;
  }
  .layout-choice:hover { border-color: var(--color-ink); }
  .layout-choice[aria-pressed='true'] {
    border-color: var(--color-accent);
    background: var(--color-canvas-soft);
    box-shadow: inset 3px 0 0 var(--color-accent);
  }
  .choice-title {
    display: block;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 750;
    line-height: 1.35;
  }
  .choice-body {
    display: block;
    margin-top: .35rem;
    color: var(--color-body-muted);
    font-family: var(--font-sans);
    font-size: .8125rem;
    line-height: 1.5;
  }
  [data-people-layout][hidden] { display: none !important; }
  @media (min-width: 48rem) and (max-width: 63.999rem) {
    :global(.directors-grid > .profile-card:last-child:nth-child(odd)) { grid-column: 1 / -1; }
  }
</style>
