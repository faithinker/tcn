---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTile from '../components/SectionTile.astro';
import Button from '../components/Button.astro';
import { getCollection } from 'astro:content';
import { formatDate, getLangFromUrl, localizePath } from '../i18n/utils';
import { getContent } from '../i18n/content';

const lang = getLangFromUrl(Astro.url);
const copy = getContent(lang).about;
const history = (await getCollection('history'))
  .filter((entry) => entry.data.lang === lang)
  .sort((a, b) => a.data.date.localeCompare(b.data.date));
---

<BaseLayout
  title={copy.title}
  description={copy.description}
>
  <section class="bg-canvas px-5 py-16 sm:py-24">
    <div class="mx-auto max-w-[75rem]">
      <p class="eyebrow">{copy.eyebrow}</p>
      {lang === 'ko' ? (
        <h1 class="mt-3 font-serif text-display-sm font-semibold text-ink sm:text-display-hero">
          <span class="block whitespace-nowrap">초문화 시대를 연구하는</span>
          <span class="block whitespace-nowrap">국제 학술 공동체</span>
        </h1>
      ) : (
        <h1 class="mt-3 max-w-[18ch] font-serif text-display-lg font-semibold text-ink sm:text-display-hero">
          {copy.heroTitle}
        </h1>
      )}
      <p class="mt-6 max-w-[62ch] font-serif text-lead text-body">
        {copy.heroBody}
      </p>
    </div>
  </section>

  <SectionTile variant="band" eyebrow={copy.missionEyebrow} title={copy.missionTitle}>
    <div class="mt-8 grid gap-6 lg:grid-cols-[1fr_1fr]">
      <p class="max-w-prose font-serif text-body-serif text-body">
        {copy.missionBodies[0]}
      </p>
      <p class="max-w-prose font-serif text-body-serif text-body">
        {copy.missionBodies[1]}
      </p>
    </div>
  </SectionTile>

  <SectionTile id="history" class="scroll-mt-20" variant="canvas" eyebrow={copy.historyEyebrow} title={copy.historyTitle}>
    <p class="mt-6 max-w-[68ch] font-serif text-body-serif text-body">
      {copy.historyBody}
    </p>
    <ol class="mt-10 border-t border-hairline-strong">
      {history.map((entry) => (
        <li class="grid gap-4 border-b border-hairline py-7 sm:grid-cols-[11rem_minmax(0,1fr)] sm:gap-8 sm:py-9">
          <time
            datetime={entry.data.date}
            class="font-sans text-body-sans font-bold text-accent"
          >
            {formatDate(entry.data.date, lang)}
          </time>
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
              <h3 class="font-serif text-display-sm font-semibold text-ink">
                {entry.data.title}
              </h3>
              <span class={`border px-2 py-1 font-sans text-caption font-bold ${entry.data.status === 'upcoming' ? 'border-accent text-accent' : 'border-hairline text-body-muted'}`}>
                {entry.data.status === 'upcoming' ? copy.historyUpcomingLabel : copy.historyPastLabel}
              </span>
            </div>
            <p class="mt-4 max-w-[68ch] font-serif text-body-serif text-body">
              {entry.data.description}
            </p>
            <dl class="mt-5 grid gap-x-6 gap-y-3 font-sans text-body-sm sm:grid-cols-[5rem_minmax(0,1fr)]">
              <dt class="font-bold text-body-muted">{copy.historyLocationLabel}</dt>
              <dd class="text-body">{entry.data.location}</dd>
              {entry.data.participants.length > 0 && (
                <>
                  <dt class="font-bold text-body-muted">{copy.historyParticipantsLabel}</dt>
                  <dd class="text-body">{entry.data.participants.join(' · ')}</dd>
                </>
              )}
            </dl>
          </div>
        </li>
      ))}
    </ol>
  </SectionTile>

  <SectionTile variant="band" eyebrow={copy.foundingEyebrow} title={copy.foundingTitle}>
    <p class="mt-6 max-w-[68ch] font-serif text-body-serif text-body">
      {copy.foundingBody}
    </p>
    <div class="mt-8">
      <Button href={localizePath('/about/founding', lang)} variant="outline">
        {copy.foundingButton}
      </Button>
    </div>
  </SectionTile>

  <SectionTile variant="canvas" eyebrow={copy.declarationEyebrow} title={copy.declarationTitle}>
    <p class="mt-6 max-w-[68ch] font-serif text-body-serif text-body">
      {copy.declarationBody}
    </p>
    <div class="mt-8">
      <Button href={localizePath('/about/declaration', lang)} variant="outline">
        {copy.declarationButton}
      </Button>
    </div>
  </SectionTile>
</BaseLayout>
