---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTile from '../components/SectionTile.astro';
import Button from '../components/Button.astro';
import { getLangFromUrl, localizePath } from '../i18n/utils';
import { getContent } from '../i18n/content';

const lang = getLangFromUrl(Astro.url);
const copy = getContent(lang).about;
---

<BaseLayout
  title={copy.title}
  description={copy.description}
>
  <section class="bg-canvas px-5 py-16 sm:py-24">
    <div class="mx-auto max-w-[75rem]">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1 class="mt-3 max-w-[14ch] font-serif text-display-lg font-semibold text-ink sm:text-display-hero">
        {copy.heroTitle}
      </h1>
      <p class="mt-6 max-w-[62ch] font-serif text-lead text-body">
        {copy.heroBody}
      </p>
    </div>
  </section>

  <SectionTile variant="band" eyebrow={copy.missionEyebrow} title={copy.missionTitle}>
    <div class="mt-8 grid gap-6 lg:grid-cols-[1fr_1fr]">
      <p class="max-w-prose font-serif text-body-serif text-body">
        {copy.missionBodies[0]}
      </p>
      <p class="max-w-prose font-serif text-body-serif text-body">
        {copy.missionBodies[1]}
      </p>
    </div>
  </SectionTile>

  <SectionTile variant="canvas" eyebrow={copy.declarationEyebrow} title={copy.declarationTitle}>
    <p class="mt-6 max-w-[68ch] font-serif text-body-serif text-body">
      {copy.declarationBody}
    </p>
    <div class="mt-8">
      <Button href={localizePath('/about/declaration', lang)} variant="outline">
        {copy.declarationButton}
      </Button>
    </div>
  </SectionTile>
</BaseLayout>
