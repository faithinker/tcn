---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedDocuments from '../../components/RelatedDocuments.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getLangFromUrl } from '../../i18n/utils';
import { getContent } from '../../i18n/content';

const lang = getLangFromUrl(Astro.url);
const copy = getContent(lang).declaration;
---

<BaseLayout
  title={copy.title}
  description={copy.description}
>
  <section class="bg-canvas px-5 py-12 sm:py-24">
    <article class="mx-auto max-w-[75rem]">
      <div class="border-y border-hairline-strong py-8">
        <p class="eyebrow">{copy.eyebrow}</p>
        <h1 class="mt-3 font-serif text-display-md font-semibold text-ink sm:text-display-lg">
          {copy.heroTitle}
        </h1>
      </div>

      <RelatedDocuments lang={lang} current="declaration" />

      <div class="mx-auto mt-10 max-w-[74ch] sm:mt-12">
        <div class="space-y-7 font-serif text-body-serif text-body">
          {copy.intro.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <ol class="mt-12 grid gap-4">
          {copy.missions.map((mission) => (
            <li class="border border-hairline bg-canvas-soft p-5 sm:p-6">
              <p class="font-sans text-caption font-bold uppercase text-accent">{mission.label}</p>
              <h2 class="mt-2 font-serif text-display-sm font-semibold text-ink">
                {mission.title}
              </h2>
              <p class="mt-4 font-serif text-body-serif text-body">{mission.body}</p>
            </li>
          ))}
        </ol>

        <div class="mt-12 space-y-7 font-serif text-body-serif text-body">
          {copy.closing.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <footer class="mt-12 border-t border-hairline pt-8">
          <p class="font-serif text-body-serif font-semibold text-ink">{copy.signature}</p>
        </footer>
      </div>
    </article>
  </section>
  <BackToTop label={copy.backToTopLabel} />
</BaseLayout>
