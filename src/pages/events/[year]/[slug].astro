---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import InvitationContent from '../../../components/InvitationContent.astro';
import { getCollection } from 'astro:content';
import { formatDate, getLangFromUrl, localizePath } from '../../../i18n/utils';
import { getContent } from '../../../i18n/content';

export async function getStaticPaths() {
  const invitations = (await getCollection('invitations')).filter((entry) => entry.data.lang === 'ko');

  return invitations.map((invitation) => ({
    params: {
      year: String(invitation.data.year),
      slug: invitation.data.slug,
    },
    props: { invitation },
  }));
}

const { invitation } = Astro.props;
const { data } = invitation;
const lang = getLangFromUrl(Astro.url);
const copy = getContent(lang).events;
---

<BaseLayout title={data.shortTitle} description={data.summary}>
  <section class="bg-canvas px-5 py-16 sm:py-24">
    <article class="mx-auto max-w-[75rem]">
      <header class="border-y border-hairline-strong py-8 sm:py-10">
        <p class="eyebrow">{copy.detailEyebrow(data.year)}</p>
        <h1 class="mt-3 max-w-[22ch] font-serif text-display-md font-semibold text-ink sm:text-display-lg">
          {data.title}
        </h1>
        <p class="mt-5 font-sans text-body-sans font-bold text-body-muted">
          {formatDate(data.date, lang)} · {data.time}
        </p>
      </header>

      <div class="mt-12 grid gap-10 lg:grid-cols-[17rem_minmax(0,1fr)]">
        <aside>
          <div class="border-l-2 border-hairline-strong pl-5 lg:sticky lg:top-28">
            <p class="font-sans text-caption font-bold uppercase text-accent">{copy.eventInfo}</p>
            <dl class="mt-5 space-y-5 font-sans text-body-sm">
              <div>
                <dt class="font-bold text-ink">{copy.date}</dt>
                <dd class="mt-1 text-body-muted">{formatDate(data.date, lang)}<br />{data.time}</dd>
              </div>
              <div>
                <dt class="font-bold text-ink">{copy.location}</dt>
                <dd class="mt-1 text-body-muted">{data.location}<br />{data.venue}</dd>
                {data.mapUrl && (
                  <dd class="mt-3">
                    <a
                      href={data.mapUrl}
                      target="_blank"
                      rel="noreferrer"
                      class="inline-flex min-h-11 items-center gap-1 font-bold text-link underline"
                    >
                      {copy.viewMap}
                      <span aria-hidden="true">↗</span>
                    </a>
                  </dd>
                )}
              </div>
            </dl>
            <a
              href={localizePath(`/events/${data.year}`, lang)}
              class="mt-8 inline-flex min-h-11 items-center font-sans text-body-sm font-bold underline"
            >
              {copy.viewYear(data.year)}
            </a>
          </div>
        </aside>

        <div class="max-w-[74ch]">
          <p class="font-sans text-caption font-bold uppercase text-accent">{copy.pastInvitation}</p>
          <div class="mt-5">
            <InvitationContent data={data} />
          </div>
        </div>
      </div>
    </article>
  </section>
</BaseLayout>
