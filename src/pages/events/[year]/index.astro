---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import InvitationContent from '../../../components/InvitationContent.astro';
import { getCollection } from 'astro:content';
import { formatDate, getLangFromUrl, localizePath } from '../../../i18n/utils';
import { getContent } from '../../../i18n/content';

export async function getStaticPaths() {
  const invitations = (await getCollection('invitations')).filter((entry) => entry.data.lang === 'ko');
  const years = [...new Set(invitations.map((entry) => entry.data.year))];

  return years.map((year) => ({
    params: { year: String(year) },
    props: { invitations: invitations.filter((entry) => entry.data.year === year) },
  }));
}

const { year } = Astro.params;
const { invitations } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const copy = getContent(lang).events;
const sortedInvitations = [...invitations].sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout title={copy.yearTitle(year!)} description={copy.yearDescription(year!)}>
  <section class="bg-canvas px-5 py-16 sm:py-24">
    <div class="mx-auto max-w-[75rem]">
      <p class="eyebrow">Events · {year}</p>
      <h1 class="mt-3 font-serif text-display-lg font-semibold text-ink sm:text-display-hero">
        {copy.yearTitle(year!)}
      </h1>
      <p class="mt-6 font-sans text-body-sans text-body-muted">
        <a href={localizePath('/events', lang)} class="font-bold">{copy.allEvents}</a> / {copy.yearLabel(year!)}
      </p>
    </div>
  </section>

  <section class="bg-canvas-band px-5 py-16 sm:py-24">
    <div class="mx-auto max-w-[75rem]">
      <p class="eyebrow">{copy.invitationsEyebrow}</p>
      <h2 class="mt-3 font-serif text-display-md font-semibold text-ink sm:text-display-lg">
        {copy.invitationTitle}
      </h2>
      <div class="mt-8 grid gap-4">
        {sortedInvitations.map((invitation) => (
          <article class="border-y border-hairline-strong bg-canvas p-6 sm:p-8">
            <p class="font-sans text-caption font-bold text-accent">
              {invitation.data.status === 'past' ? copy.pastInvitation : copy.invitation}
            </p>
            <h3 class="mt-2 font-serif text-display-sm font-semibold text-ink">
              <a
                href={localizePath(`/events/${invitation.data.year}/${invitation.data.slug}`, lang)}
                class="text-ink no-underline hover:text-link"
              >
                {invitation.data.title}
              </a>
            </h3>
            <p class="mt-3 font-sans text-body-sans text-body-muted">
              {formatDate(invitation.data.date, lang)} · {invitation.data.location}
            </p>
            <p class="mt-5 max-w-[68ch] font-serif text-body-serif text-body">
              {invitation.data.summary}
            </p>

            <details class="invitation-details group mt-7 border-t border-hairline">
              <summary
                class="invitation-summary flex min-h-14 cursor-pointer list-none items-center justify-between gap-4 font-sans text-body-sans font-bold text-link"
              >
                <span class="group-open:hidden">{copy.expand}</span>
                <span class="hidden group-open:inline">{copy.collapse}</span>
                <svg
                  aria-hidden="true"
                  class="h-5 w-5 shrink-0 transition-transform duration-150 group-open:rotate-180"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.25"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m6 9 6 6 6-6"></path>
                </svg>
              </summary>

              <div class="border-t border-hairline pb-2">
                <InvitationContent data={invitation.data} compact />
                <a
                  href={localizePath(`/events/${invitation.data.year}/${invitation.data.slug}`, lang)}
                  class="mt-8 inline-flex min-h-12 items-center font-sans text-body-sans font-bold underline"
                >
                  {copy.standalone}
                </a>
              </div>
            </details>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .invitation-summary {
    list-style: none;
  }

  .invitation-summary::-webkit-details-marker {
    display: none;
  }

  .invitation-summary::marker {
    content: '';
  }
</style>
