---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { formatDate, getLangFromUrl, localizePath } from '../../i18n/utils';
import { getContent } from '../../i18n/content';

export async function getStaticPaths() {
  const seminars = (await getCollection('seminars')).filter((entry) => entry.data.lang === 'ko');
  return seminars.map((seminar) => ({
    params: { slug: seminar.data.slug },
    props: { seminar },
  }));
}

interface Props {
  seminar: CollectionEntry<'seminars'>;
}

const { seminar } = Astro.props as Props;
const { data } = seminar;
const lang = getLangFromUrl(Astro.url);
const copy = getContent(lang).seminars;

const badge = data.status === 'upcoming' ? copy.upcomingBadge : copy.pastBadge;
const hasBody = Boolean(
  data.summary || data.abstract || data.theme || data.speaker ||
  (data.program && data.program.length) ||
  (data.speakers && data.speakers.length) ||
  (data.materials && data.materials.length),
);
---

<BaseLayout title={data.title} description={data.summary ?? data.abstract ?? copy.description}>
  <section class="bg-canvas px-5 py-16 sm:py-24">
    <article class="mx-auto max-w-[75rem]">
      <a
        href={localizePath('/seminars', lang)}
        class="inline-flex min-h-[44px] items-center font-sans text-body-sm font-bold text-link no-underline hover:text-link-hover"
      >← {copy.backToList}</a>

      <header class="mt-4 border-y border-hairline-strong py-8 sm:py-10">
        <div class="flex flex-wrap items-center gap-3">
          <p class="eyebrow !mb-0">{data.status === 'upcoming' ? copy.nextEyebrow : copy.pastEyebrow}</p>
          <span class="inline-flex items-center rounded-sm bg-accent px-2 py-0.5 font-sans text-caption font-bold uppercase text-on-primary">{badge}</span>
        </div>
        <h1 class="mt-4 font-serif text-display-md font-semibold text-ink sm:text-display-lg">{data.title}</h1>
        <p class="mt-5 font-sans text-body-sans font-bold text-body-muted">
          {formatDate(data.date, lang)} · {data.location}
        </p>
      </header>

      <div class="mt-10 max-w-[68ch]">
        {data.theme && (
          <p class="font-serif text-lead text-body">{data.theme}</p>
        )}
        {(data.summary || data.abstract) && (
          <p class="mt-6 font-serif text-body-serif text-body">{data.summary ?? data.abstract}</p>
        )}

        {data.tags && data.tags.length > 0 && (
          <div class="mt-8">
            <p class="font-sans text-caption font-bold uppercase text-accent">{copy.participantsLabel}</p>
            <p class="mt-2 font-serif text-body-serif text-body">{data.tags.join(' · ')}</p>
          </div>
        )}

        {data.program && data.program.length > 0 && (
          <section class="mt-10 border-t border-hairline-strong pt-8">
            <p class="font-sans text-caption font-bold uppercase text-accent">{copy.programLabel}</p>
            <ul class="mt-4 space-y-2 font-serif text-body-serif text-body">
              {data.program.map((item) => <li>· {item}</li>)}
            </ul>
          </section>
        )}

        {data.speakers && data.speakers.length > 0 && (
          <section class="mt-10 border-t border-hairline-strong pt-8">
            <p class="font-sans text-caption font-bold uppercase text-accent">{copy.speakersLabel}</p>
            <ul class="mt-4 space-y-2 font-serif text-body-serif text-body">
              {data.speakers.map((item) => <li>· {item}</li>)}
            </ul>
          </section>
        )}

        {data.materials && data.materials.length > 0 && (
          <section class="mt-10 border-t border-hairline-strong pt-8">
            <p class="font-sans text-caption font-bold uppercase text-accent">{copy.materialsLabel}</p>
            <ul class="mt-4 space-y-2 font-sans text-body-sans">
              {data.materials.map((m) => (
                <li>
                  <a href={m.url} class="font-bold text-link underline hover:text-link-hover">{m.label}</a>
                </li>
              ))}
            </ul>
          </section>
        )}

        {!hasBody && (
          <p class="font-serif text-body-serif text-body">{copy.details}</p>
        )}
      </div>
    </article>
  </section>
</BaseLayout>
