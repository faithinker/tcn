---
// L7: Home — Hero · 미션 · 핵심활동 · 최신 세미나 · 하이라이트 · 가입 CTA.
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTile from '../components/SectionTile.astro';
import Stat from '../components/Stat.astro';
import Button from '../components/Button.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, formatDate, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const seminars = (await getCollection('seminars')).filter((s) => s.data.lang === lang);
const upcoming = seminars
  .filter((s) => s.data.status === 'upcoming')
  .sort((a, b) => a.data.date.localeCompare(b.data.date));
const past = seminars
  .filter((s) => s.data.status === 'past')
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
const featured = upcoming[0] ?? past[0];

const activities = ['국제 세미나 개최', '공동연구', '인력 교류', '정책 대안 제시'];

const highlights = [
  { value: '2025', label: '창립' },
  { value: '15', label: '창립국' },
  { value: '1', label: '세미나' },
  { value: '서울', label: '사무국' },
];
---

<BaseLayout>
  <!-- 1. Hero -->
  <section class="bg-canvas px-5 pt-16 pb-14 sm:pt-24 sm:pb-20">
    <div class="mx-auto max-w-[75rem]">
      <p class="eyebrow">국제 학술 네트워크</p>
      <h1 class="mt-3 font-serif font-semibold text-ink text-[1.75rem] leading-[1.2] sm:text-[2rem]">
        초문화네트워크
      </h1>
      <p class="mt-1 font-serif font-semibold text-body-muted text-[1.375rem] leading-[1.25] sm:text-[1.625rem]">
        Transcultural Network
      </p>
      <p class="mt-6 max-w-[60ch] font-serif text-[1.3125rem] leading-[1.6] text-body">
        국가·민족·언어·문화의 경계를 넘어 새로운 제3의 문화를 창조하는 국제 학술 네트워크입니다.
      </p>
      <p class="mt-4 max-w-[60ch] font-sans text-body-sans text-body-muted">
        디지털·AI 시대의 문화 교류와 창조를 연구합니다.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href={localizePath('/contact', lang)} variant="primary">가입·문의</Button>
        <Button href={localizePath('/about', lang)} variant="outline">학회 소개</Button>
      </div>
    </div>
  </section>

  <!-- 2. 미션 -->
  <SectionTile variant="band" eyebrow="미션" title="설립 취지">
    <p class="mt-6 max-w-[68ch] font-serif text-lead text-body">
      국경 없는 디지털·AI 시대에 문화의 교류와 새로운 문화의 창조가 지속되고 있습니다.
      초문화네트워크는 이 과정을 규명하고, 더 나은 문화 창조에 기여하고자 합니다.
    </p>
    <div class="mt-10 grid gap-8 border-t border-hairline pt-8 sm:grid-cols-2">
      <div>
        <p class="eyebrow">비전</p>
        <p class="mt-2 font-serif text-body-serif text-body">
          인류가 공존하고 인간이 존중받는 문화 창조를 지향합니다.
        </p>
      </div>
      <div>
        <p class="eyebrow">미션</p>
        <p class="mt-2 font-serif text-body-serif text-body">
          각국의 전문가가 지혜와 경험을 공유합니다.
        </p>
      </div>
    </div>
  </SectionTile>

  <!-- 3. 핵심 활동 -->
  <SectionTile variant="canvas" eyebrow="활동" title="핵심 활동">
    <ol class="mt-8 grid gap-x-8 gap-y-6 sm:grid-cols-2">
      {
        activities.map((a, i) => (
          <li class="border-t border-hairline pt-4">
            <span class="eyebrow">{String(i + 1).padStart(2, '0')}</span>
            <p class="mt-1 font-serif text-display-sm font-semibold text-ink">{a}</p>
          </li>
        ))
      }
    </ol>
  </SectionTile>

  <!-- 4. 최신 세미나 -->
  {
    featured && (
      <SectionTile variant="soft" eyebrow="세미나">
        <article class="mt-6 max-w-[68ch]">
          <p class="eyebrow">{featured.data.status === 'upcoming' ? '예정' : '지난 행사'}</p>
          <h3 class="mt-2 font-serif text-display-md font-semibold text-ink">{featured.data.title}</h3>
          <p class="mt-3 font-serif text-byline font-bold text-body-muted">
            {formatDate(featured.data.date, lang)} · {featured.data.location}
          </p>
          <p class="mt-4 font-serif text-body-serif text-body">
            {featured.data.abstract ?? '주제와 연사는 추후 안내됩니다.'}
          </p>
          <div class="mt-6">
            <Button href={localizePath('/seminars', lang)} variant="outline">
              세미나 전체 보기
            </Button>
          </div>
        </article>
      </SectionTile>
    )
  }

  <!-- 5. 하이라이트 -->
  <SectionTile variant="band" eyebrow="하이라이트">
    <div class="mt-8 grid grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-4">
      {highlights.map((h) => <Stat value={h.value} label={h.label} />)}
    </div>
  </SectionTile>

  <!-- 6. 가입 CTA -->
  <SectionTile variant="canvas">
    <div class="max-w-[68ch]">
      <p class="eyebrow">함께하기</p>
      <h2 class="mt-3 font-serif text-display-md font-semibold text-ink sm:text-display-lg">
        회원 가입·문의
      </h2>
      <p class="mt-4 font-serif text-body-serif text-body">
        초문화네트워크의 연구와 국제 학술 협력에 참여를 원하시면 문의해 주세요.
      </p>
      <div class="mt-8">
        <Button href={localizePath('/contact', lang)} variant="primary">가입·문의</Button>
      </div>
    </div>
  </SectionTile>
</BaseLayout>
