---
// People — 임원(Board: 회장·수석부회장·이사4·감사) + 국제 전문가(예시).
// 콘텐츠: TCN 확정 임원 + 참여 연구자(예시). 디자인: 기존 시스템(SectionTile/MemberCard).
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTile from '../components/SectionTile.astro';
import MemberCard from '../components/MemberCard.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const members = (await getCollection('members')).filter((m) => m.data.lang === lang);
const board = members
  .filter((m) => m.data.category === 'board')
  .sort((a, b) => a.data.order - b.data.order);
const experts = members
  .filter((m) => m.data.category === 'member')
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="구성원" description="초문화네트워크의 임원진과 참여 연구자">
  <!-- 페이지 헤더 -->
  <section class="bg-canvas px-5 py-16 sm:py-24">
    <div class="mx-auto max-w-[75rem]">
      <p class="eyebrow">People</p>
      <h1 class="mt-3 max-w-[14ch] font-serif text-display-lg font-semibold text-ink sm:text-display-hero">
        구성원
      </h1>
      <p class="mt-6 max-w-[62ch] font-serif text-lead text-body">
        다양한 지역과 분야의 전문가들이 초문화 연구와 국제 학술 협력을 함께합니다.
      </p>
    </div>
  </section>

  <!-- 임원 (Board) -->
  <SectionTile variant="band" eyebrow="Board" title="임원진">
    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {board.map((m) => <MemberCard {...m.data} />)}
    </div>
  </SectionTile>

  <!-- 국제 전문가 (예시) -->
  {
    experts.length > 0 && (
      <SectionTile variant="canvas" eyebrow="Researchers" title="참여 연구자">
        <p class="mt-3 max-w-[68ch] font-sans text-body-sm text-body-muted">
          제1차 세미나(2025년 라오스 루앙프라방) 참여 연구자. ※ 아래는 예시 데이터로, 실제 명단
          확보 시 교체됩니다.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {experts.map((m) => <MemberCard {...m.data} />)}
        </div>
      </SectionTile>
    )
  }
</BaseLayout>
