---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTile from '../components/SectionTile.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getContent } from '../i18n/content';

const lang = getLangFromUrl(Astro.url);
const copy = getContent(lang).people;
const t = useTranslations(lang);
const members = (await getCollection('members'))
  .filter((member) => member.data.lang === lang && member.data.category === 'board')
  .sort((a, b) => a.data.order - b.data.order);

const namedMembers = members.filter((member) => !member.data.tba);
const pendingMembers = members.filter((member) => member.data.tba);
---

<BaseLayout
  title={copy.title}
  description={copy.description}
>
  <section class="bg-canvas px-5 py-12 sm:py-24">
    <div class="mx-auto max-w-[75rem]">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1 class="mt-3 font-serif text-display-lg font-semibold text-ink sm:text-display-hero">
        {copy.heroTitle}
      </h1>
      <p class="mt-6 max-w-[62ch] font-serif text-lead text-body">
        {copy.heroBody}
      </p>
    </div>
  </section>

  <SectionTile variant="band" eyebrow={copy.leadershipEyebrow} title={copy.leadershipTitle}>
    <div class="mt-8 grid gap-px border-y border-hairline-strong bg-hairline lg:grid-cols-2">
      {namedMembers.map((member) => (
        <article class="min-w-0 bg-canvas p-5 sm:p-8">
          <p class="font-sans text-caption font-bold uppercase text-accent">
            {member.data.role}
          </p>
          <h2 class="mt-2 font-serif text-display-sm font-semibold text-ink">
            {member.data.name}
          </h2>
          {member.data.nameEn && (
            <p class="mt-1 font-sans text-body-sm font-bold text-body-muted">
              {member.data.nameEn}
            </p>
          )}
          {member.data.bio && (
            <ul class="mt-5 max-w-[58ch] space-y-2 font-serif text-body-serif text-body">
              {member.data.bio.map((item) => (
                <li class="grid grid-cols-[0.75rem_minmax(0,1fr)] gap-1">
                  <span aria-hidden="true">·</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          )}
          {member.data.affiliation && (
            <p class="mt-5 max-w-[58ch] font-serif text-body-serif text-body">
              {member.data.affiliation}
            </p>
          )}
        </article>
      ))}
    </div>
  </SectionTile>

  {pendingMembers.length > 0 && (
    <SectionTile variant="canvas" eyebrow={copy.boardEyebrow} title={copy.boardTitle}>
      <p class="mt-6 max-w-[68ch] font-serif text-body-serif text-body">
        {copy.boardBody}
      </p>
      <div class="mt-8 grid gap-px border-y border-hairline-strong bg-hairline sm:grid-cols-2 lg:grid-cols-4">
        {pendingMembers.map((member) => (
          <article class="min-w-0 bg-canvas p-5 sm:p-6">
            <p class="font-sans text-caption font-bold uppercase text-accent">
              {member.data.country}
            </p>
            <h2 class="mt-2 font-serif text-[1.375rem] font-semibold text-ink">
              {member.data.role}
            </h2>
            <p class="mt-3 font-sans text-body-sm font-bold text-body-muted">
              {t('common.tba')}
            </p>
          </article>
        ))}
      </div>
    </SectionTile>
  )}
</BaseLayout>
