---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout
  title="페이지를 찾을 수 없습니다"
  description="요청하신 초문화네트워크 페이지를 찾을 수 없습니다."
  noindex
>
  <section class="bg-canvas px-5 py-24 sm:py-32">
    <div class="mx-auto max-w-[75rem]">
      <p class="eyebrow">404</p>
      <h1 class="mt-3 font-serif text-display-lg font-semibold text-ink sm:text-display-hero">
        페이지를 찾을 수 없습니다
      </h1>
      <p class="mt-6 max-w-[62ch] font-serif text-lead text-body">
        주소가 변경되었거나 아직 공개되지 않은 페이지입니다.
      </p>
      <div class="mt-8">
        <Button href="/" variant="primary">홈으로 이동</Button>
      </div>
    </div>
  </section>
</BaseLayout>
