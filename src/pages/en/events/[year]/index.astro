---
import YearPage from '../../../events/[year]/index.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const invitations = (await getCollection('invitations')).filter((entry) => entry.data.lang === 'en');
  const years = [...new Set(invitations.map((entry) => entry.data.year))];

  return years.map((year) => ({
    params: { year: String(year) },
    props: { invitations: invitations.filter((entry) => entry.data.year === year) },
  }));
}

const { invitations } = Astro.props;
---

<YearPage invitations={invitations} />
