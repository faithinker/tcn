---
import SeminarDetail from '../../../page-templates/seminars/seminar-detail.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const seminars = (await getCollection('seminars')).filter((entry) => entry.data.lang === 'en');
  return seminars.map((seminar) => ({
    params: { slug: seminar.data.slug },
    props: { seminar },
  }));
}

const { seminar } = Astro.props;
---

<SeminarDetail seminar={seminar} />
