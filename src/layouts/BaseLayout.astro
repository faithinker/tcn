---
// L4: 공통 셸 — head/meta, 스킵링크, Header, main, Footer. 단일 밝은 테마(ThemeToggle 없음).
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/og/tcn-default.png',
  type = 'website',
  noindex = false,
} = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const siteName = t('site.name');
const pageTitle = title ? `${title} | ${siteName}` : `${siteName} | ${t('site.nameEn')}`;
const desc = description ?? t('site.tagline');
const siteRoot = Astro.site ?? Astro.url;
const canonicalURL = new URL(Astro.url.pathname, siteRoot);
const socialImageURL = new URL(image, siteRoot);
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  alternateName: t('site.nameEn'),
  url: new URL('/', siteRoot).href,
  logo: new URL('/icon-512.png', siteRoot).href,
  description: t('site.tagline'),
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <meta name="theme-color" content="#141414" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content={lang === 'ko' ? 'ko_KR' : 'en_US'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="초문화네트워크 · Transcultural Network" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={socialImageURL} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationJsonLd)} />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only rounded-sm bg-ink px-4 py-2 font-sans font-bold text-on-primary focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100]"
    >
      {t('common.skipToContent')}
    </a>
    <Header lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
