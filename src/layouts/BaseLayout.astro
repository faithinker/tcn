---
// L4: 공통 셸 — head/meta, 스킵링크, Header, main, Footer. 단일 밝은 테마(ThemeToggle 없음).
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, stripLangPrefix, switchLangPath, useTranslations } from '../i18n/utils';
// perf: 마스트헤드·히어로("초문화네트워크 / Transcultural Network") 글리프를 담은
// Noto Serif KR 600 서브셋 4개(총 ~67KB)를 preload — 렌더블로킹 CSS 파싱을 기다리지
// 않고 폰트를 병렬 다운로드해 LCP 단축. ?url이라 CSS의 unicode-range 파일과 동일
// 해시 URL → 이중 다운로드 없음. en은 Georgia 폴백이라 ko에서만 주입.
import notoKr116 from '@fontsource/noto-serif-kr/files/noto-serif-kr-116-600-normal.woff2?url';
import notoKr117 from '@fontsource/noto-serif-kr/files/noto-serif-kr-117-600-normal.woff2?url';
import notoKr118 from '@fontsource/noto-serif-kr/files/noto-serif-kr-118-600-normal.woff2?url';
import notoKr119 from '@fontsource/noto-serif-kr/files/noto-serif-kr-119-600-normal.woff2?url';
// 폰트 @font-face 번들(수백 KB)은 렌더를 막지 않도록 별도 CSS로 비차단 로드.
// media="print" → onload에서 all로 전환(표준 async CSS 패턴), noscript 폴백 제공.
import fontsCssUrl from '../styles/fonts.css?url';

const preloadFonts = [notoKr116, notoKr117, notoKr118, notoKr119];

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/og/tcn-default.png',
  type = 'website',
  noindex = false,
} = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const siteName = t('site.name');
const pageTitle = title && title !== siteName
  ? `${title} | ${siteName}`
  : lang === 'ko'
    ? `${siteName} | ${t('site.nameEn')}`
    : siteName;
const socialTitle = siteName;
const desc = description ?? t('site.tagline');
const siteRoot = Astro.site ?? Astro.url;
const canonical = new URL(Astro.url.pathname, siteRoot);
const koUrl = new URL(switchLangPath(Astro.url.pathname, 'ko'), siteRoot);
const enUrl = new URL(switchLangPath(Astro.url.pathname, 'en'), siteRoot);
const xDefaultUrl = stripLangPrefix(Astro.url.pathname) === '/' ? new URL('/', siteRoot) : enUrl;
const socialImageURL = new URL(image, siteRoot);
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  alternateName: lang === 'ko' ? t('site.nameEn') : 'TCN',
  url: new URL('/', siteRoot).href,
  logo: new URL('/icon-512.png', siteRoot).href,
  description: t('site.tagline'),
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    {lang === 'ko' && preloadFonts.map((href) => (
      <link rel="preload" as="font" type="font/woff2" href={href} crossorigin />
    ))}
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <meta name="theme-color" content="#141414" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ko" href={koUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content={lang === 'ko' ? 'ko_KR' : 'en_US'} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={lang === 'ko' ? '초문화네트워크 · Transcultural Network' : 'Transcultural Network'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={socialImageURL} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationJsonLd)} />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only rounded-sm bg-ink px-4 py-2 font-sans font-bold text-on-primary focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100]"
    >
      {t('common.skipToContent')}
    </a>
    <Header lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <!-- 폰트 @font-face 번들: body 끝 로드 — 뒤 콘텐츠 없어 첫 페인트 비차단.
         텍스트는 폴백으로 즉시 그려지고 크리티컬 서브셋은 head preload가 조기 확보. -->
    <link rel="stylesheet" href={fontsCssUrl} />
    <script>
      import '../scripts/reveal.ts';
    </script>
  </body>
</html>
